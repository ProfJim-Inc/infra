{
  "title": "Judwaa Agent — Service Health",
  "uid": "judwaa-agent-health",
  "tags": ["judwaa", "agent", "avatar"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (all services)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"production\", job=~\"agent-backend|agent-frontend\"}[2m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"production\", job=\"agent-backend\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"production\", job=\"agent-backend\"}[5m]))",
          "legendFormat": "agent-backend error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P99 Latency — agent-backend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"production\", job=\"agent-backend\"}[5m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"production\", job=\"agent-backend\"}[5m])) by (le, handler))",
          "legendFormat": "p50 {{handler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Avatar Jobs — Created vs Completed vs Failed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(agent_avatar_jobs_created_total[10m])",
          "legendFormat": "created (10m)"
        },
        {
          "expr": "increase(agent_avatar_jobs_completed_total[10m])",
          "legendFormat": "completed (10m)"
        },
        {
          "expr": "increase(agent_avatar_jobs_failed_total[10m])",
          "legendFormat": "failed (10m)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Active Pipeline Jobs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "agent_active_pipeline_jobs",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Pipeline P95 Duration",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_pipeline_duration_seconds_bucket[1h]))",
          "legendFormat": "p95 duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1200, "color": "yellow" },
              { "value": 3600, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Pod Availability",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"production\", deployment=\"agent-backend\"}",
          "legendFormat": "backend"
        },
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"production\", deployment=\"agent-frontend\"}",
          "legendFormat": "frontend"
        },
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"production\", deployment=\"agent-worker\"}",
          "legendFormat": "worker"
        },
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"production\", deployment=\"agent-worker-bg\"}",
          "legendFormat": "worker-bg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 2, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Audio Generation Duration P95 (ElevenLabs)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_audio_generation_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 audio gen"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "title": "Image Generation Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(agent_image_generation_errors_total[5m]) / rate(agent_image_generation_requests_total[5m])",
          "legendFormat": "image gen error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.15, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
